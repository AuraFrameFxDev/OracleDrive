com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# App-level build folders
app/build/

# Exclude app specific build folders
app/*/build/

# Exclude all build folders in all modules
**/build/

# Exclude generated files
**/generated/

# Exclude local test results
**/local/

# Exclude generated source
**/generated/source/

# Exclude generated R files
**/generated/res/

# Exclude generated data binding files
**/generated/data_binding_base_class_source_out/

# Exclude lint results
**/lint/

# Exclude test results
**/test-results/
**/testReport/

# Exclude coverage reports
**/coverage/

# Exclude Firebase config
**/google-services.json
**/google-services-debug.json
**/google-services-release.json

# Exclude app signing configs
**/keystore/
**/*.keystore
**/*.jks

# Exclude local development files
**/local.properties
**/*.iml
**/.idea/

# Exclude build cache
.cache/

# Exclude node modules (if using React Native)
node_modules/

# Exclude npm debug logs
npm-debug.log*

# Exclude C++ build files
**/*.o
**/*.so

# Exclude Kotlin build files
**/*.kotlin_module
**/kotlin/

# Exclude Java annotation processing
**/*_Factory.class
**/*_MembersInjector.class
**/*_Provide*Factory.class
**/Dagger*Component*.class
**/Dagger*Component$Builder.class
**/*Module_*Factory.class

# Exclude AndroidX Navigation safe args
**/*-args/
**/*-args/args/
