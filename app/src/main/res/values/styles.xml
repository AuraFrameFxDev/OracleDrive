<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme - Using Theme.GenesisAndroidApp directly instead -->

    <!-- TextInputLayout Style -->
    <style name="Widget.GenesisAndroidApp.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/terminal_accent</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">4dp</item>
        <item name="boxCornerRadiusTopEnd">4dp</item>
        <item name="boxCornerRadiusBottomStart">4dp</item>
        <item name="boxCornerRadiusBottomEnd">4dp</item>
        <item name="hintTextColor">@color/terminal_accent</item>
        <item name="hintTextAppearance">@style/TextAppearance.GenesisAndroidApp.Hint</item>
        <item name="android:textColorHint">@color/terminal_highlight</item>
        <item name="android:textColor">@color/terminal_fg</item>
    </style>

    <!-- Hint Text Appearance -->
    <style name="TextAppearance.GenesisAndroidApp.Hint" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/terminal_accent</item>
    </style>
</resources>
