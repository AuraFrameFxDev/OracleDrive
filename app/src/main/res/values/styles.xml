<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:fontFamily">@font/pixelify_sans_medium</item>
        <item name="fontFamily">@font/pixelify_sans_medium</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowAnimationStyle">@style/DisperseMaterialization</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowEnterTransition">@transition/explode</item>
        <item name="android:windowExitTransition">@transition/explode</item>
        <item name="android:windowSharedElementEnterTransition">@transition/move</item>
        <item name="android:windowSharedElementExitTransition">@transition/move</item>
        <item name="android:buttonStyle">@style/NeonButton</item>
        <item name="android:editTextStyle">@style/NeonEditText</item>
    </style>

    <!-- Dark theme for the app -->
    <style name="AppTheme.Dark" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/teal_200</item>
        <item name="android:fontFamily">@font/pixelify_sans_medium</item>
        <item name="fontFamily">@font/pixelify_sans_medium</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowAnimationStyle">@style/DisperseMaterialization</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowEnterTransition">@transition/explode</item>
        <item name="android:windowExitTransition">@transition/explode</item>
        <item name="android:windowSharedElementEnterTransition">@transition/move</item>
        <item name="android:windowSharedElementExitTransition">@transition/move</item>
    </style>

    <!-- Text appearance style used by the app -->
    <style name="TerminalTextAppearance" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/terminal_fg</item>
        <item name="android:shadowColor">@color/terminal_highlight</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">10</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Add custom font for Pixelify Sans Medium -->
    <font-family xmlns:app="http://schemas.android.com/apk/res-auto"
        app:fontProviderAuthority="com.google.android.gms.fonts"
        app:fontProviderPackage="com.google.android.gms"
        app:fontProviderQuery="Pixelify Sans Medium"
        app:fontProviderCerts="@array/com_google_android_gms_fonts_certs" />

    <style name="DisperseMaterialization">
        <item name="android:activityOpenEnterAnimation">@anim/disperse_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/disperse_out</item>
    </style>

    <!-- Enhanced immersive navigation bar and status bar appearance -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
    </style>

    <style name="NeonButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">@color/neon_teal</item>
        <item name="android:shadowColor">@color/neon_teal</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">8</item>
    </style>
    <style name="NeonEditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/edittext_background</item>
        <item name="android:textColor">@color/neon_teal</item>
        <item name="android:shadowColor">@color/neon_teal</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">8</item>
    </style>
</resources>
