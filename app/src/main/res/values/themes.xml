<resources>
    <!-- Base application theme -->
    <style name="Theme.GenesisAndroidApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/terminal_fg</item>
        <item name="colorPrimaryVariant">@color/terminal_accent</item>
        <item name="colorOnPrimary">@color/black</item>

        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/terminal_accent</item>
        <item name="colorSecondaryVariant">@color/terminal_highlight</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/background</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/terminal_fg</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/terminal_fg</item>
        <item name="android:textColorSecondary">@color/terminal_highlight</item>
        <item name="android:textColor">@color/terminal_fg</item>

        <!-- Dialog -->
        <item name="alertDialogTheme">@style/ThemeOverlay.AppCompat.Dark</item>
        <item name="dialogTheme">@style/ThemeOverlay.AppCompat.Dialog</item>

        <!-- Material Components -->
        <item name="materialButtonStyle">@style/Widget.GenesisAndroidApp.Button</item>
        <item name="editTextStyle">@style/Widget.GenesisAndroidApp.EditText</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.GenesisAndroidApp.Button" parent="@style/Widget.AppCompat.Button">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:padding">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- EditText Style -->
    <style name="Widget.GenesisAndroidApp.EditText" parent="@style/Widget.AppCompat.EditText">
        <item name="android:textColor">@color/terminal_fg</item>
        <item name="android:textColorHint">@color/terminal_fg</item>
        <item name="android:backgroundTint">@color/terminal_accent</item>
        <item name="android:background">@drawable/edittext_background</item>
    </style>

    <!-- CardView Style -->
    <style name="Widget.GenesisAndroidApp.CardView" parent="@style/Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Text Appearance -->
    <style name="TerminalTextAppearance" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@color/terminal_fg</item>
        <item name="android:shadowColor">@color/terminal_highlight</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">10</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Dialog Theme reference - defined in styles.xml -->
</resources>