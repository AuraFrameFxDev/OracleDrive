<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background color -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
            <stroke
                android:width="1dp"
                android:color="@color/terminal_accent" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Glow effect -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="@color/terminal_highlight" />
            <corners android:radius="4dp" />
            <padding 
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp" />
        </shape>
    </item>
</layer-list>
